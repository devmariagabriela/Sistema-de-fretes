        <conditionalStyle>
            <conditionExpression><![CDATA[$F{status} != null && "OCORRENCIA".equals($F{status}.name())]]></conditionExpression>
            <style backcolor="#FEE2E2" forecolor="#B91C1C"/>
        </conditionalStyle>
        <conditionalStyle>
            <conditionExpression><![CDATA[$F{status} != null && "CANCELADO".equals($F{status}.name())]]></conditionExpression>
            <style backcolor="#E5E7EB" forecolor="#4B5563"/>
        </conditionalStyle>
    </style>

