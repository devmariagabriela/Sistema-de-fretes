<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>GW FRETE</display-name>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>br.com.gwfrete.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.LoginController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.LogoutController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.DashboardController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DashboardController</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UsuarioController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.UsuarioController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UsuarioController</servlet-name>
        <url-pattern>/usuarios</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>UsuarioController</servlet-name>
        <url-pattern>/usuarios/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ClienteController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.ClienteController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ClienteController</servlet-name>
        <url-pattern>/clientes</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ClienteController</servlet-name>
        <url-pattern>/clientes/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>VeiculoController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.VeiculoController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>VeiculoController</servlet-name>
        <url-pattern>/veiculos</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>VeiculoController</servlet-name>
        <url-pattern>/veiculos/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManutencaoVeiculoController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.ManutencaoVeiculoController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ManutencaoVeiculoController</servlet-name>
        <url-pattern>/manutencoes</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ManutencaoVeiculoController</servlet-name>
        <url-pattern>/manutencoes/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MotoristaController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.MotoristaController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MotoristaController</servlet-name>
        <url-pattern>/motoristas</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>MotoristaController</servlet-name>
        <url-pattern>/motoristas/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>FreteController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.FreteController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>FreteController</servlet-name>
        <url-pattern>/fretes</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>FreteController</servlet-name>
        <url-pattern>/fretes/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OcorrenciaFreteController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.OcorrenciaFreteController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>OcorrenciaFreteController</servlet-name>
        <url-pattern>/ocorrencias-frete</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>OcorrenciaFreteController</servlet-name>
        <url-pattern>/ocorrencias-frete/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RelatorioController</servlet-name>
        <servlet-class>br.com.gwfrete.controller.RelatorioController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RelatorioController</servlet-name>
        <url-pattern>/relatorios/fretes</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>RelatorioController</servlet-name>
        <url-pattern>/relatorios/fretes/pdf</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
